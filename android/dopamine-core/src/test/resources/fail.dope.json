{
  "fmt": "dopamine-effect",
  "v": "1.0.0",
  "id": "dopamine.error.fail",
  "meta": {
    "name": "Fail Stamp",
    "description": "A failure/denied moment — the emotional opposite of the success effects. A red/amber cross is stamped in over a recoiling error flare with a sharp hit + shake, then desaturates and collapses. Short and punchy.",
    "tags": [
      "error",
      "fail",
      "denied",
      "negative"
    ]
  },
  "controls": {
    "mood": {
      "type": "enum",
      "label": "Mood",
      "default": "error",
      "options": [
        "try-again",
        "error",
        "denied"
      ],
      "ui": "segmented"
    },
    "intensity": {
      "type": "scalar",
      "label": "Severity",
      "default": 0.7,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider",
      "help": "How hard the failure lands: flare heat/size, shake amount, recoil."
    },
    "whimsy": {
      "type": "scalar",
      "label": "Whimsy",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider",
      "help": "Photoreal flare (0) to desaturated RGB-split glitch collapse (1)."
    },
    "seed": {
      "type": "int",
      "label": "Seed",
      "default": null,
      "nullable": true,
      "help": "Null = unique error palette per fire; pin to reproduce."
    },
    "origin": {
      "type": "point",
      "label": "Origin",
      "default": "center"
    },
    "target": {
      "type": "selector",
      "label": "Target",
      "default": "document.body"
    }
  },
  "baselines": {
    "try-again": {
      "durationMs": 900,
      "lightness": 0.78,
      "chroma": 0.13,
      "hueCenter": 70,
      "hueRange": 40,
      "shakeAmount": 0.5
    },
    "error": {
      "durationMs": 760,
      "lightness": 0.72,
      "chroma": 0.17,
      "hueCenter": 40,
      "hueRange": 36,
      "shakeAmount": 0.85
    },
    "denied": {
      "durationMs": 640,
      "lightness": 0.66,
      "chroma": 0.21,
      "hueCenter": 22,
      "hueRange": 30,
      "shakeAmount": 1.25
    }
  },
  "palette": {
    "model": "oklch",
    "space": "linear-srgb",
    "generator": "golden-angle",
    "goldenAngleDeg": 137.50776405003785,
    "stops": 3,
    "hueSpread": 0.18,
    "lightness": {
      "baseline": "lightness",
      "perStop": [
        0,
        0.06,
        -0.05
      ]
    },
    "chroma": {
      "from": {
        "mul": [
          {
            "baseline": "chroma"
          },
          {
            "lerp": [
              "intensity",
              0.8,
              1.4
            ]
          }
        ]
      },
      "perStop": [
        0,
        0.02,
        -0.01
      ]
    },
    "seed": {
      "deterministic": true,
      "source": "controls.seed",
      "prng": "mulberry32",
      "note": "Algorithmic OKLCH biased to error reds/ambers: a narrow hueRange around a hot hueCenter keeps every fire inside the red/amber error band while still being generated (unique per fire)."
    },
    "perMood": {
      "try-again": {
        "hueCenter": 70,
        "hueRange": 40,
        "lightness": 0.78,
        "chroma": 0.13
      },
      "error": {
        "hueCenter": 40,
        "hueRange": 36,
        "lightness": 0.72,
        "chroma": 0.17
      },
      "denied": {
        "hueCenter": 22,
        "hueRange": 30,
        "lightness": 0.66,
        "chroma": 0.21
      }
    }
  },
  "tempo": {
    "durationMs": {
      "from": {
        "round": {
          "mul": [
            {
              "baseline": "durationMs"
            },
            {
              "lerp": [
                "intensity",
                1.15,
                0.85
              ]
            }
          ]
        }
      }
    },
    "frame": {
      "amp": {
        "lt": [
          {
            "clamp01": {
              "input": "life"
            }
          },
          0.05,
          {
            "easeOutCubic": {
              "div": [
                {
                  "clamp01": {
                    "input": "life"
                  }
                },
                0.05
              ]
            }
          },
          {
            "lt": [
              {
                "clamp01": {
                  "input": "life"
                }
              },
              0.55,
              1,
              {
                "pow": [
                  {
                    "clamp01": {
                      "sub": [
                        1,
                        {
                          "div": [
                            {
                              "sub": [
                                {
                                  "clamp01": {
                                    "input": "life"
                                  }
                                },
                                0.55
                              ]
                            },
                            0.45
                          ]
                        }
                      ]
                    }
                  },
                  1.7
                ]
              }
            ]
          }
        ]
      },
      "extras": {
        "stamp": {
          "sub": [
            1,
            {
              "pow": [
                {
                  "sub": [
                    1,
                    {
                      "clamp01": {
                        "div": [
                          {
                            "input": "elapsedMs"
                          },
                          170
                        ]
                      }
                    }
                  ]
                },
                5
              ]
            }
          ]
        },
        "shake": {
          "lt": [
            0,
            {
              "input": "elapsedMs"
            },
            {
              "mul": [
                {
                  "sin": {
                    "mul": [
                      {
                        "div": [
                          {
                            "input": "elapsedMs"
                          },
                          300
                        ]
                      },
                      3.141592653589793,
                      7
                    ]
                  }
                },
                {
                  "exp": {
                    "div": [
                      {
                        "sub": [
                          0,
                          {
                            "input": "elapsedMs"
                          }
                        ]
                      },
                      {
                        "mul": [
                          300,
                          0.35
                        ]
                      }
                    ]
                  }
                },
                {
                  "param": "shakeAmount"
                }
              ]
            },
            0
          ]
        }
      }
    },
    "reducedMotion": {
      "peakMs": 200,
      "holdMs": 320
    },
    "note": "The negative, punchy counterpart to the held-breath success envelope: frame.amp is the slam/hold/collapse fail envelope; stamp (the ✗ slash-in over 170 ms) and shake (a damped ~3.5-oscillation recoil over 300 ms) run on the REAL un-stepped clock (elapsedMs) on every platform."
  },
  "geometry": {
    "kind": "radial",
    "viewBox": [
      0,
      0,
      100,
      100
    ],
    "outlines": {
      "cross": {
        "role": "deny-glyph",
        "source": "baked-sdf",
        "note": "GEOMETRY SEAM: the ✗ icon is driven by this svgPath, baked to the inline SDF below (scripts/bake-sdf.mjs). The fail shader samples it (uSdfTex). Swap the path + re-bake to change the rejected icon with no shader edit. Two diagonal bars (a clean cross).",
        "svgPath": "M 24 24 L 76 76 M 76 24 L 24 76",
        "sdf": {
          "size": 64,
          "range": 18,
          "viewBox": [
            0,
            0,
            100,
            100
          ],
          "data": "data:application/octet-stream;base64,"
        }
      }
    }
  },
  "content": {
    "note": "No word set for the fail effect — the ✗ cross is the whole message. Kept here for symmetry with the other effects' content blocks.",
    "tokens": [
      "✗"
    ]
  },
  "render": {
    "params": {
      "exposure": {
        "type": "float",
        "from": {
          "lerp": [
            "intensity",
            0.9,
            1.6
          ]
        }
      },
      "severity": {
        "type": "float",
        "from": {
          "control": "intensity"
        }
      },
      "shakeAmount": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "shakeAmount"
            },
            {
              "lerp": [
                "intensity",
                0.7,
                1.3
              ]
            }
          ]
        }
      },
      "style": {
        "type": "float",
        "from": {
          "control": "whimsy"
        }
      }
    },
    "shadowHeightFrac": 0.42,
    "consts": {},
    "config": {
      "usesOrigin": true
    },
    "backends": {
      "webgl2": {
        "stage": "fullscreen-triangle",
        "blend": "screen",
        "shader": {
          "program": "fail"
        }
      }
    },
    "fallbackOrder": [
      "webgl2"
    ]
  },
  "binding": {
    "note": "CROSS-PLATFORM uniform-binding contract. Which render.params are NOT shader uniforms, the seed-keyed scatter field (no scatterWeb — the fail shader reads no seed uniform), the per-frame/host extras, and the texture samplers — one source of truth for the web u<Name> list, the Swift struct + packer, and the MSL struct. SHIPS in the portable .dope (the runtime derives its uniform bindings from it); the toolchain consumes it too for the Metal struct codegen. Only `x-build`, `slug` and `kind` stay toolchain-only.",
    "excludeParams": [
      "style",
      "shakeAmount",
      "seed"
    ],
    "scatterKey": "failSeed",
    "extras": [
      {
        "name": "stamp",
        "type": "float",
        "web": "uStamp",
        "note": "stampProgress(animMs)"
      },
      {
        "name": "shake",
        "type": "float",
        "web": "uShake",
        "note": "signed recoil shake (-1..1)"
      },
      {
        "name": "sdfOn",
        "type": "float",
        "web": "uSdfOn",
        "note": "1 = drive the cross from the baked SDF"
      },
      {
        "name": "sdfRangePx",
        "type": "float",
        "web": "uSdfRangePx",
        "note": "device px mapping to the SDF 0..1 range"
      },
      {
        "name": "sdfStrokePx",
        "type": "float",
        "web": "uSdfStrokePx",
        "note": "half stroke width (device px)"
      },
      {
        "name": "boxPx",
        "type": "float",
        "web": "uBoxPx",
        "note": "half-size (device px) of the ✗ box"
      }
    ],
    "samplers": [
      {
        "web": "uSdfTex",
        "name": "sdfTex",
        "texture": 1
      }
    ]
  }
}
