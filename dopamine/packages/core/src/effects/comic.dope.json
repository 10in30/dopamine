{
  "fmt": "dopamine-effect",
  "v": "1.0.0",
  "id": "dopamine.success.comic",
  "meta": {
    "name": "Comic Impact",
    "description": "A Golden/Silver-Age comic-book success shout: a hand-lettered affirmation slams in over a jagged starburst with halftone + action lines.",
    "tags": ["success", "comic", "impact"]
  },
  "controls": {
    "mood": { "type": "enum", "label": "Mood", "default": "celebratory", "options": ["serene", "celebratory", "electric"], "ui": "segmented" },
    "intensity": { "type": "scalar", "label": "Intensity", "default": 0.7, "min": 0, "max": 1, "step": 0.01, "ui": "slider", "help": "Slam force, word size, spike + line count, saturation." },
    "whimsy": { "type": "scalar", "label": "Whimsy", "default": 0.5, "min": 0, "max": 1, "step": 0.01, "ui": "slider", "help": "Noir chiaroscuro (0) to full pop-art Ben-Day (1)." },
    "seed": { "type": "int", "label": "Seed", "default": null, "nullable": true, "help": "Null = unique palette + word per fire; pin to reproduce." },
    "target": { "type": "selector", "label": "Target", "default": "document.body" }
  },
  "baselines": {
    "serene": {
      "durationMs": 2400, "lightness": 0.82, "chroma": 0.1, "hueCenter": 230, "hueRange": 120,
      "scale": 0.34, "burstPoints": 14, "actionLines": 18, "overshoot": 0.55
    },
    "celebratory": {
      "durationMs": 1900, "lightness": 0.82, "chroma": 0.18, "hueCenter": 50, "hueRange": 320,
      "scale": 0.4, "burstPoints": 20, "actionLines": 30, "overshoot": 1.0
    },
    "electric": {
      "durationMs": 1500, "lightness": 0.8, "chroma": 0.24, "hueCenter": 35, "hueRange": 150,
      "scale": 0.46, "burstPoints": 28, "actionLines": 44, "overshoot": 1.45
    }
  },
  "palette": {
    "model": "oklch",
    "space": "linear-srgb",
    "generator": "golden-angle",
    "goldenAngleDeg": 137.50776405003785,
    "stops": 3,
    "hueSpread": 0.55,
    "lightness": { "baseline": "lightness", "perStop": [0.0, 0.06, -0.05] },
    "chroma": {
      "from": { "mul": [{ "baseline": "chroma" }, { "lerp": ["intensity", 0.7, 1.5] }] },
      "perStop": [0.0, 0.02, -0.01]
    },
    "seed": { "deterministic": true, "source": "controls.seed", "prng": "mulberry32" },
    "perMood": {
      "serene": { "hueCenter": 230, "hueRange": 120, "lightness": 0.82, "chroma": 0.1 },
      "celebratory": { "hueCenter": 50, "hueRange": 320, "lightness": 0.82, "chroma": 0.18 },
      "electric": { "hueCenter": 35, "hueRange": 150, "lightness": 0.8, "chroma": 0.24 }
    }
  },
  "tempo": {
    "durationMs": {
      "from": { "round": { "mul": [{ "baseline": "durationMs" }, { "lerp": ["intensity", 1.1, 0.9] }] } }
    }
  },
  "geometry": {
    "kind": "radial",
    "viewBox": [0, 0, 100, 100],
    "outlines": {
      "starburst": { "role": "burst", "note": "Procedural jagged star drawn in comic-renderer drawPanel from burstPoints + comicSeed." }
    }
  },
  "render": {
    "params": {
      "exposure": { "type": "float", "from": { "lerp": ["intensity", 0.85, 1.5] } },
      "overshoot": {
        "type": "float",
        "from": { "mul": [{ "baseline": "overshoot" }, { "lerp": ["intensity", 0.7, 1.3] }] }
      },
      "scale": {
        "type": "float",
        "from": { "mul": [{ "baseline": "scale" }, { "lerp": ["intensity", 0.85, 1.12] }] }
      },
      "burstPoints": {
        "type": "int",
        "from": { "round": { "mul": [{ "baseline": "burstPoints" }, { "lerp": ["intensity", 0.8, 1.2] }] } }
      },
      "actionLines": {
        "type": "int",
        "from": { "round": { "mul": [{ "baseline": "actionLines" }, { "lerp": ["intensity", 0.7, 1.25] }] } }
      },
      "halftone": { "type": "float", "clamp01": true, "from": { "lerp": ["whimsy", 0.28, 1.0] } },
      "dotSize": { "type": "float", "from": { "lerp": ["whimsy", 5.0, 11.0] } },
      "saturation": {
        "type": "float", "clamp01": true,
        "from": { "mul": [{ "lerp": ["whimsy", 0.18, 1.0] }, { "lerp": ["intensity", 0.8, 1.1] }] }
      },
      "inkWeight": {
        "type": "float",
        "from": { "mul": [{ "lerp": ["whimsy", 5.0, 12.0] }, { "lerp": ["intensity", 0.85, 1.1] }] }
      },
      "style": { "type": "float", "from": { "control": "whimsy" } }
    },
    "backends": {
      "webgl2": {
        "stage": "fullscreen-triangle",
        "blend": "screen",
        "shader": { "program": "comic" },
        "note": "Hybrid: a Canvas2D panel (word/burst/ink) is uploaded as a texture; the shader adds halftone, action lines, flash, styling."
      }
    },
    "fallbackOrder": ["webgl2"]
  }
}
