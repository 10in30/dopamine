{
  "fmt": "dopamine-effect",
  "v": "1.0.0",
  "id": "dopamine.loading.halo",
  "meta": {
    "name": "Halo",
    "description": "A calm ambient loading indicator: a soft luminous ring of light centred on the origin that gently rotates and breathes, with a traveling highlight arc sweeping around it (the 'loading' read). Dopamine's first CONTINUOUS effect — it LOOPS SEAMLESSLY via the first-class tempo.loop contract: all motion is driven by the standard periodic clocks uPhase/uLoopS the runners derive from tempo.loop.periodMs (1500 ms). The parser validates the seam invariants (the period is exactly 18 'animate-on-twos' steps, NPR_TIME_STEP_MS = 1000/12, and durationMs 6000 is exactly 4 periods), so the frame at t==durationMs matches t==0 at every whimsy. The conductor re-arms at durationMs instead of tearing down; the host stops it via the play handle. amp is a steady gentle periodic breathe of phase (NOT envelope(life)), so there is no one-shot fade to break the seam.",
    "tags": [
      "loading",
      "ambient",
      "continuous",
      "looping"
    ]
  },
  "controls": {
    "mood": {
      "type": "enum",
      "default": "celebratory",
      "options": [
        "serene",
        "celebratory",
        "electric"
      ],
      "ui": "segmented"
    },
    "intensity": {
      "type": "scalar",
      "default": 0.7,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider"
    },
    "whimsy": {
      "type": "scalar",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider"
    },
    "seed": {
      "type": "int",
      "default": null,
      "nullable": true
    },
    "origin": {
      "type": "point",
      "default": "center"
    },
    "target": {
      "type": "selector",
      "default": "document.body"
    }
  },
  "baselines": {
    "serene": {
      "durationMs": 6000,
      "lightness": 0.86,
      "chroma": 0.08,
      "hueCenter": 225,
      "hueRange": 110,
      "ringRadius": 0.3,
      "ringWidth": 0.07,
      "breathe": 0.16,
      "sweepArc": 0.34,
      "sweepTurns": 1,
      "glow": 0.55
    },
    "celebratory": {
      "durationMs": 6000,
      "lightness": 0.82,
      "chroma": 0.15,
      "hueCenter": 200,
      "hueRange": 280,
      "ringRadius": 0.31,
      "ringWidth": 0.06,
      "breathe": 0.2,
      "sweepArc": 0.4,
      "sweepTurns": 2,
      "glow": 0.7
    },
    "electric": {
      "durationMs": 6000,
      "lightness": 0.8,
      "chroma": 0.22,
      "hueCenter": 195,
      "hueRange": 160,
      "ringRadius": 0.32,
      "ringWidth": 0.045,
      "breathe": 0.24,
      "sweepArc": 0.46,
      "sweepTurns": 3,
      "glow": 0.95
    }
  },
  "palette": {
    "model": "oklch",
    "space": "linear-srgb",
    "generator": "golden-angle",
    "goldenAngleDeg": 137.50776405003785,
    "stops": 3,
    "hueSpread": 0.55,
    "lightness": {
      "baseline": "lightness",
      "perStop": [
        0,
        0.06,
        -0.05
      ]
    },
    "chroma": {
      "from": {
        "mul": [
          {
            "baseline": "chroma"
          },
          {
            "lerp": [
              "intensity",
              0.7,
              1.5
            ]
          }
        ]
      },
      "perStop": [
        0,
        0.02,
        -0.01
      ]
    },
    "seed": {
      "deterministic": true,
      "source": "controls.seed",
      "prng": "mulberry32"
    },
    "perMood": {
      "serene": {
        "hueCenter": 225,
        "hueRange": 110,
        "lightness": 0.86,
        "chroma": 0.08
      },
      "celebratory": {
        "hueCenter": 200,
        "hueRange": 280,
        "lightness": 0.82,
        "chroma": 0.15
      },
      "electric": {
        "hueCenter": 195,
        "hueRange": 160,
        "lightness": 0.8,
        "chroma": 0.22
      }
    }
  },
  "tempo": {
    "durationMs": {
      "from": {
        "baseline": "durationMs"
      }
    },
    "loop": {
      "periodMs": 1500
    },
    "frame": {
      "amp": {
        "add": [
          0.85,
          {
            "mul": [
              0.15,
              {
                "sin": {
                  "mul": [
                    6.283185307179586,
                    {
                      "input": "phase"
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "extras": {}
    },
    "reducedMotion": {
      "peakMs": 0,
      "holdMs": 600
    }
  },
  "render": {
    "params": {
      "exposure": {
        "type": "float",
        "from": {
          "lerp": [
            "intensity",
            0.7,
            1.45
          ]
        }
      },
      "ringRadius": {
        "type": "float",
        "from": {
          "baseline": "ringRadius"
        }
      },
      "ringWidth": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "ringWidth"
            },
            {
              "lerp": [
                "intensity",
                1.25,
                0.78
              ]
            }
          ]
        }
      },
      "breathe": {
        "type": "float",
        "from": {
          "baseline": "breathe"
        }
      },
      "sweepArc": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "sweepArc"
            },
            {
              "lerp": [
                "intensity",
                0.8,
                1.2
              ]
            }
          ]
        }
      },
      "sweepTurns": {
        "type": "int",
        "from": {
          "round": {
            "baseline": "sweepTurns"
          }
        }
      },
      "glow": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "glow"
            },
            {
              "lerp": [
                "intensity",
                0.6,
                1.3
              ]
            }
          ]
        }
      },
      "style": {
        "type": "float",
        "from": {
          "control": "whimsy"
        }
      }
    },
    "shadowHeightFrac": {
      "min": [
        {
          "add": [
            {
              "param": "ringRadius"
            },
            {
              "mul": [
                {
                  "param": "ringWidth"
                },
                2
              ]
            }
          ]
        },
        1
      ]
    },
    "consts": {},
    "config": {
      "usesOrigin": true
    },
    "backends": {
      "webgl2": {
        "stage": "fullscreen-triangle",
        "blend": "screen",
        "shader": {
          "program": "halo"
        }
      }
    },
    "fallbackOrder": [
      "webgl2"
    ]
  },
  "binding": {
    "note": "CROSS-PLATFORM uniform-binding contract. Which render.params are NOT shader uniforms, the seed-keyed scatter field, the per-frame/host extras, and the texture samplers — one source of truth for the web u<Name> list, the Swift struct + packer, and the MSL struct. SHIPS in the portable .dope (the runtime derives its uniform bindings from it); the toolchain consumes it too for the Metal struct codegen. Only `x-build`, `slug` and `kind` stay toolchain-only. haloSeed feeds the seeded palette only (no scatterWeb — the shader reads no seed uniform).",
    "excludeParams": [
      "style"
    ],
    "scatterKey": "haloSeed",
    "extras": [],
    "samplers": []
  }
}
