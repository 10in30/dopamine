node_modules/
dist/
.build/
# The AGGREGATE root SwiftPM manifest (scripts/swift-aggregate.mjs): its effect
# target paths point into the gitignored dist/swift/ trees, so it is valid only
# next to a fresh `dopamine build`. The release workflow generates it and commits
# it onto the tagged release tree — it never lives on `main`.
/Package.swift
# Toolchain-generated portable .dope synced into a web workspace's src. The single
# source is effects/<id>/<slug>.dope.json; `dopamine build` regenerates these.
effects/*/web/src/*.dope.json
# Toolchain-generated per-frame-geometry logic parity gate (the generated Kotlin
# renderer + JUnit grid test + fixture copy) synced into dopamine-core's test
# sources; `dopamine build` regenerates these from effects/<id>/web sources.
android/dopamine-core/src/testGenerated/
*.tsbuildinfo
e2e/output/
test-results/
.playwright/
.DS_Store

# Claude Code agent worktrees / local scratch
.claude/
