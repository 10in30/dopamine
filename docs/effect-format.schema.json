{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dopamine.dev/schemas/dope-1.0.0.json",
  "title": "Dopamine Effect Format (.dope)",
  "description": "Declarative, renderer-agnostic format for Dopamine visual effects (file extension .dope). Inspired-by-Lottie: reuses Lottie keyframe + shape encodings at the leaves, but is parametric (controls -> mappings -> render params -> backend) at the top.",
  "type": "object",
  "required": ["fmt", "v", "id", "controls", "palette", "tempo", "render"],
  "additionalProperties": true,
  "properties": {
    "fmt": { "const": "dopamine-effect" },
    "v": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)*$" },
    "extends": { "type": "string" },
    "meta": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "author": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },

    "controls": {
      "type": "object",
      "description": "The introspectable feeling API. Each control is a UI-renderable descriptor.",
      "additionalProperties": { "$ref": "#/$defs/control" },
      "properties": {
        "mood":      { "$ref": "#/$defs/control" },
        "intensity": { "$ref": "#/$defs/control" },
        "whimsy":    { "$ref": "#/$defs/control" }
      }
    },

    "baselines": {
      "type": "object",
      "description": "Per-mood baseline table the mapping grammar's { baseline: X } nodes read (color register + the effect's own spatial/motion/typographic baselines). The loader (framework/loader.ts) resolves these. Keyed by mood name; each mood carries the effect's exact tuned values so loader output is byte-identical on every platform.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "number" }
      }
    },

    "palette": {
      "type": "object",
      "required": ["model", "generator"],
      "properties": {
        "model": { "const": "oklch" },
        "space": { "enum": ["linear-srgb", "srgb"], "default": "linear-srgb" },
        "generator": { "enum": ["golden-angle", "explicit"] },
        "goldenAngleDeg": { "type": "number" },
        "stops": { "type": "integer", "minimum": 1 },
        "hueStep": { "$ref": "#/$defs/exprOrNumber" },
        "hueSpread": { "type": "number" },
        "baseHue": {
          "type": "object",
          "properties": {
            "from": { "enum": ["rng", "const"] },
            "center": { "$ref": "#/$defs/exprOrNumber" },
            "range": { "$ref": "#/$defs/exprOrNumber" }
          }
        },
        "lightness": { "$ref": "#/$defs/channelSpec" },
        "chroma": { "$ref": "#/$defs/channelSpec" },
        "seed": {
          "type": "object",
          "properties": {
            "deterministic": { "type": "boolean" },
            "source": { "type": "string" },
            "prng": { "const": "mulberry32" },
            "note": { "type": "string" }
          }
        },
        "perMood": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "hueCenter": { "type": "number" },
              "hueRange": { "type": "number" },
              "lightness": { "type": "number" },
              "chroma": { "type": "number" }
            }
          }
        },
        "override": {
          "type": "array",
          "description": "Host theme: explicit OKLCH stops that bypass the generator.",
          "items": { "$ref": "#/$defs/oklch" }
        }
      }
    },

    "tempo": {
      "type": "object",
      "properties": {
        "durationMs": { "$ref": "#/$defs/paramExpr" },
        "frame": {
          "type": "object",
          "description": "Per-frame logic (§7.1): the effect's frame() hook as frame-expression trees, evaluated each frame against animMs/life/elapsedMs + the resolved params. `amp` feeds shadow geometry / uAmp; `extras` are keyed by the canonical binding.extras[].name.",
          "required": ["amp"],
          "properties": {
            "amp": { "$ref": "#/$defs/frameExpr" },
            "extras": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/frameExpr" }
            }
          }
        },
        "loop": {
          "type": "object",
          "description": "Continuous-loop contract (§7.2): the effect repeats seamlessly with period periodMs. Parsers validate the seam invariants: unless snapAligned is false, periodMs must be a whole number of animate-on-twos steps (1000/12 ms), and every baseline durationMs must be a whole number of periods. Runners derive the standard periodic clocks (uLoopS/uPhase + the loopS/phase frame inputs) from it; conductors re-arm at durationMs instead of tearing down.",
          "required": ["periodMs"],
          "properties": {
            "periodMs": { "type": "number", "exclusiveMinimum": 0 },
            "snapAligned": { "type": "boolean", "default": true }
          }
        },
        "reducedMotion": {
          "type": "object",
          "description": "Reduced-motion handling: the calm-peak elapsedMs and how long to hold that single static frame.",
          "properties": {
            "peakMs": { "type": "number" },
            "holdMs": { "type": "number" }
          }
        },
        "confirm": {
          "type": "object",
          "properties": {
            "kind": { "const": "draw-window" },
            "windowMs": { "type": "object", "properties": { "perEffect": { "type": "object" } } },
            "progress": { "$ref": "#/$defs/curveRef" }
          }
        },
        "envelope": {
          "type": "object",
          "properties": {
            "curve": { "$ref": "#/$defs/curveRef" },
            "overshoot": { "type": "object", "properties": { "param": { "type": "string" } } }
          }
        },
        "stepping": {
          "type": "object",
          "properties": { "curve": { "$ref": "#/$defs/curveRef" } }
        },
        "curves": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/curve" }
        }
      }
    },

    "geometry": {
      "type": "object",
      "properties": {
        "kind": { "enum": ["radial", "directional"] },
        "viewBox": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
        "outlines": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/outline" }
        }
      }
    },

    "render": {
      "type": "object",
      "required": ["params", "backends"],
      "properties": {
        "params": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/paramSpec" }
        },
        "derived": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/paramExpr" }
        },
        "shadowHeightFrac": {
          "$ref": "#/$defs/frameExpr",
          "description": "Shadow occluder height as a fraction of min canvas dim: a bare number or a PARAMS-ONLY frame expression ({input} nodes are rejected at runtime)."
        },
        "pass": {
          "type": "object",
          "description": "PER-PASS scalar uniforms (§8.2), keyed by the canonical binding.extras[].name: frame expressions evaluated once per pass over the resolved params + the pass-geometry inputs (targetMinDimPx / sdfRange / sdfViewBoxW). Frame clocks (animMs/life/elapsedMs/loopS/phase) are rejected at runtime. A `note` key is documentation.",
          "properties": {
            "note": { "type": "string" }
          },
          "additionalProperties": { "$ref": "#/$defs/frameExpr" }
        },
        "consts": {
          "type": "object",
          "description": "Loop-cap constants the paramSpec clampMax/clampMin flags reference (MAX_RINGS, MAX_DROPS, ...).",
          "additionalProperties": { "type": "number" }
        },
        "config": {
          "type": "object",
          "description": "Generic-runner config.",
          "properties": {
            "usesOrigin": { "type": "boolean" }
          }
        },
        "backends": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/backend" }
        },
        "fallbackOrder": { "type": "array", "items": { "type": "string" } }
      }
    },

    "binding": {
      "type": "object",
      "description": "The cross-platform uniform-binding contract (§8.2). SHIPS in the portable doc: the runtime derives its uniform bindings from it; the @dopamine/build toolchain also consumes it for the Metal Uniforms struct codegen.",
      "properties": {
        "note": { "type": "string" },
        "excludeParams": { "type": "array", "items": { "type": "string" } },
        "scatterKey": { "type": ["string", "null"] },
        "scatterWeb": { "type": "string" },
        "extras": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "web": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        },
        "samplers": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["web"],
                "properties": {
                  "web": { "type": "string" },
                  "name": { "type": "string" },
                  "texture": { "type": "integer" },
                  "outline": { "type": "string", "description": "Declarative SDF source: a geometry.outlines key whose baked SDF backs this sampler (bound as an aux texture on web; native runtimes keep the analytic fallback)." },
                  "on": { "type": "string", "description": "The canonical binding.extras name of the sampler's on flag (1 when the texture is bound, 0 = analytic fallback)." },
                  "note": { "type": "string" }
                }
              }
            ]
          }
        }
      }
    },

    "compat": {
      "type": "object",
      "properties": {
        "lottieFallback": {
          "oneOf": [
            { "type": "object", "properties": { "$ref": { "type": "string" } }, "required": ["$ref"] },
            { "type": "object", "description": "inline Lottie animation" }
          ]
        }
      }
    }
  },

  "$defs": {
    "control": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["enum", "scalar", "int", "point", "selector"] },
        "label": { "type": "string" },
        "help": { "type": "string" },
        "ui": { "type": "string" },
        "default": {},
        "nullable": { "type": "boolean" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "options": { "type": "array", "items": { "type": "string" } },
        "appliesWhen": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "enum" } } },
          "then": { "required": ["options"] }
        }
      ]
    },

    "expr": {
      "description": "Mapping mini-grammar: a non-Turing-complete arithmetic tree over controls + mood baselines.",
      "oneOf": [
        { "type": "number" },
        { "type": "object", "properties": { "const": { "type": "number" } }, "required": ["const"] },
        { "type": "object", "properties": { "control": { "type": "string" } }, "required": ["control"] },
        { "type": "object", "properties": { "baseline": { "type": "string" } }, "required": ["baseline"] },
        { "type": "object", "properties": { "lerp": { "type": "array", "minItems": 3, "maxItems": 3,
            "prefixItems": [ { "type": "string" }, { "type": "number" }, { "type": "number" } ] } }, "required": ["lerp"] },
        { "type": "object", "properties": { "mul": { "type": "array", "items": { "$ref": "#/$defs/expr" } } }, "required": ["mul"] },
        { "type": "object", "properties": { "add": { "type": "array", "items": { "$ref": "#/$defs/expr" } } }, "required": ["add"] },
        { "type": "object", "properties": { "sub": { "type": "array", "items": { "$ref": "#/$defs/expr" } } }, "required": ["sub"] },
        { "type": "object", "properties": { "round": { "$ref": "#/$defs/expr" } }, "required": ["round"] },
        { "type": "object", "properties": { "floor": { "$ref": "#/$defs/expr" } }, "required": ["floor"] },
        { "type": "object", "properties": { "curve": { "type": "array" } }, "required": ["curve"] },
        { "type": "object", "properties": { "expr": { "type": "string", "description": "string formula; restricted whitelist of identifiers/ops" } }, "required": ["expr"] }
      ]
    },
    "exprOrNumber": { "$ref": "#/$defs/expr" },

    "frameExpr": {
      "description": "Per-FRAME expression grammar (§7.1): a non-Turing-complete arithmetic tree over the frame inputs (animMs/life/elapsedMs, the §7.2 loop clocks loopS/phase), the resolved params, and the tempo primitives. Evaluated every frame by framework/frame-expr.ts (and its Swift/Android ports); reduce order is significant for float parity. The same grammar serves render.shadowHeightFrac (params-only: every input rejected) and render.pass (the pass-geometry inputs targetMinDimPx/sdfRange/sdfViewBoxW allowed INSTEAD of the frame clocks) — which inputs are legal where is enforced at runtime.",
      "oneOf": [
        { "type": "number" },
        { "type": "object", "properties": { "const": { "type": "number" } }, "required": ["const"] },
        { "type": "object", "properties": { "param": { "type": "string" } }, "required": ["param"] },
        { "type": "object", "properties": { "input": { "enum": ["animMs", "life", "elapsedMs", "loopS", "phase", "targetMinDimPx", "sdfRange", "sdfViewBoxW"] } }, "required": ["input"] },
        { "type": "object", "properties": { "add": { "type": "array", "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["add"] },
        { "type": "object", "properties": { "sub": { "type": "array", "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["sub"] },
        { "type": "object", "properties": { "mul": { "type": "array", "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["mul"] },
        { "type": "object", "properties": { "div": { "type": "array", "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["div"] },
        { "type": "object", "properties": { "min": { "type": "array", "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["min"] },
        { "type": "object", "properties": { "max": { "type": "array", "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["max"] },
        { "type": "object", "properties": { "pow": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["pow"] },
        { "type": "object", "properties": { "sin": { "$ref": "#/$defs/frameExpr" } }, "required": ["sin"] },
        { "type": "object", "properties": { "exp": { "$ref": "#/$defs/frameExpr" } }, "required": ["exp"] },
        { "type": "object", "properties": { "clamp01": { "$ref": "#/$defs/frameExpr" } }, "required": ["clamp01"] },
        { "type": "object", "properties": { "lt": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["lt"] },
        { "type": "object", "properties": { "envelope": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["envelope"] },
        { "type": "object", "properties": { "easeOutCubic": { "$ref": "#/$defs/frameExpr" } }, "required": ["easeOutCubic"] },
        { "type": "object", "properties": { "easeOutBack": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "$ref": "#/$defs/frameExpr" } } }, "required": ["easeOutBack"] }
      ]
    },

    "paramExpr": {
      "type": "object",
      "properties": { "from": { "$ref": "#/$defs/expr" }, "param": { "type": "string" } }
    },

    "paramSpec": {
      "type": "object",
      "required": ["type", "from"],
      "properties": {
        "type": { "enum": ["float", "int"] },
        "from": { "$ref": "#/$defs/expr" },
        "clamp01": { "type": "boolean" },
        "clampMax": { "type": "string", "description": "name of a known constant, e.g. MAX_MOTES" },
        "clampMin": { "type": "string" }
      }
    },

    "channelSpec": {
      "type": "object",
      "properties": {
        "baseline": { "type": "string" },
        "from": { "$ref": "#/$defs/expr" },
        "perStop": { "type": "array", "items": { "type": "number" } }
      }
    },

    "oklch": {
      "type": "object",
      "required": ["L", "C", "h"],
      "properties": {
        "L": { "type": "number", "minimum": 0, "maximum": 1 },
        "C": { "type": "number", "minimum": 0 },
        "h": { "type": "number" }
      }
    },

    "curve": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["bezier", "step"] },
        "domain": { "enum": ["life", "timeSeconds", "norm"] },
        "gridHz": { "type": "number" },
        "blendControl": { "type": "string" },
        "generator": { "type": "object" },
        "note": { "type": "string" },
        "keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/keyframe" }
        }
      }
    },

    "keyframe": {
      "description": "Lottie-compatible keyframe. t=time, s=value(s), i/o=bezier handles, h=1 -> HOLD (step). This is exactly Lottie's keyframe object.",
      "type": "object",
      "required": ["t"],
      "properties": {
        "t": { "type": "number" },
        "s": { "type": "array" },
        "e": { "type": "array" },
        "h": { "enum": [0, 1] },
        "i": { "type": "object", "properties": { "x": { "type": "array" }, "y": { "type": "array" } } },
        "o": { "type": "object", "properties": { "x": { "type": "array" }, "y": { "type": "array" } } }
      }
    },

    "outline": {
      "description": "An icon/glyph outline. Provide svgPath OR a Lottie shape (i/o/v).",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "svgPath": { "type": "string" },
        "lottie": {
          "type": "object",
          "description": "Lottie shape vertex data.",
          "required": ["v"],
          "properties": {
            "c": { "type": "boolean" },
            "v": { "type": "array", "items": { "type": "array", "items": { "type": "number" } } },
            "i": { "type": "array", "items": { "type": "array", "items": { "type": "number" } } },
            "o": { "type": "array", "items": { "type": "array", "items": { "type": "number" } } }
          }
        }
      },
      "anyOf": [ { "required": ["svgPath"] }, { "required": ["lottie"] } ]
    },

    "curveRef": {
      "oneOf": [
        { "type": "string", "pattern": "^\\$ref:" },
        { "$ref": "#/$defs/curve" }
      ]
    },

    "backend": {
      "type": "object",
      "properties": {
        "stage": { "type": "string" },
        "blend": { "enum": ["screen", "add", "normal", "multiply"] },
        "strategy": { "type": "string" },
        "fallbackOf": { "type": "string" },
        "caps": { "type": "array", "items": { "type": "string" } },
        "shader": { "type": "object", "properties": { "$ref": { "type": "string" } } },
        "uniforms": { "type": "object", "additionalProperties": { "type": "string" } },
        "note": { "type": "string" }
      }
    }
  }
}
