{
  "fmt": "dopamine-effect",
  "v": "1.0.0",
  "id": "dopamine.celebrate.confetti",
  "slug": "confetti",
  "kind": "overlay",
  "meta": {
    "name": "Confetti",
    "description": "A burst of paper confetti launches upward from the action then tumbles down under gravity with air-drag flutter — spinning rectangles and petals in many OKLCH hues that sway, settle, and fade. The signature is the downward, physical, fluttering fall (deliberately distinct from Solarbloom's upward drifting motes).",
    "tags": [
      "celebrate",
      "success",
      "particles"
    ]
  },
  "controls": {
    "mood": {
      "type": "enum",
      "default": "celebratory",
      "options": [
        "serene",
        "celebratory",
        "electric"
      ],
      "ui": "segmented"
    },
    "intensity": {
      "type": "scalar",
      "default": 0.75,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider"
    },
    "whimsy": {
      "type": "scalar",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider"
    },
    "seed": {
      "type": "int",
      "default": null,
      "nullable": true
    },
    "origin": {
      "type": "point",
      "default": "center"
    }
  },
  "baselines": {
    "serene": {
      "durationMs": 3000,
      "lightness": 0.86,
      "chroma": 0.07,
      "hueCenter": 210,
      "hueRange": 150,
      "pieceCount": 34,
      "spread": 0.42,
      "launchSpeed": 0.78,
      "gravity": 0.62,
      "flutter": 0.55,
      "pieceSize": 1.12,
      "spin": 0.7
    },
    "celebratory": {
      "durationMs": 2300,
      "lightness": 0.82,
      "chroma": 0.16,
      "hueCenter": 45,
      "hueRange": 340,
      "pieceCount": 70,
      "spread": 0.62,
      "launchSpeed": 1.0,
      "gravity": 0.9,
      "flutter": 0.85,
      "pieceSize": 1.0,
      "spin": 1.0
    },
    "electric": {
      "durationMs": 1900,
      "lightness": 0.8,
      "chroma": 0.23,
      "hueCenter": 320,
      "hueRange": 300,
      "pieceCount": 100,
      "spread": 0.82,
      "launchSpeed": 1.28,
      "gravity": 1.05,
      "flutter": 1.15,
      "pieceSize": 0.9,
      "spin": 1.35
    }
  },
  "palette": {
    "model": "oklch",
    "space": "linear-srgb",
    "generator": "golden-angle",
    "goldenAngleDeg": 137.50776405003785,
    "stops": 3,
    "hueSpread": 0.85,
    "lightness": {
      "baseline": "lightness",
      "perStop": [
        0,
        0.05,
        -0.06
      ]
    },
    "chroma": {
      "from": {
        "mul": [
          {
            "baseline": "chroma"
          },
          {
            "lerp": [
              "intensity",
              0.7,
              1.6
            ]
          }
        ]
      },
      "perStop": [
        0,
        0.03,
        -0.01
      ]
    },
    "seed": {
      "deterministic": true,
      "source": "controls.seed",
      "prng": "mulberry32"
    },
    "perMood": {
      "serene": {
        "hueCenter": 210,
        "hueRange": 150,
        "lightness": 0.86,
        "chroma": 0.07
      },
      "celebratory": {
        "hueCenter": 45,
        "hueRange": 340,
        "lightness": 0.82,
        "chroma": 0.16
      },
      "electric": {
        "hueCenter": 320,
        "hueRange": 300,
        "lightness": 0.8,
        "chroma": 0.23
      }
    }
  },
  "tempo": {
    "durationMs": {
      "from": {
        "round": {
          "mul": [
            {
              "baseline": "durationMs"
            },
            {
              "lerp": [
                "intensity",
                1.15,
                0.85
              ]
            }
          ]
        }
      }
    }
  },
  "render": {
    "params": {
      "exposure": {
        "type": "float",
        "from": {
          "lerp": [
            "intensity",
            0.95,
            1.45
          ]
        }
      },
      "pieceCount": {
        "type": "float",
        "from": {
          "round": {
            "mul": [
              {
                "baseline": "pieceCount"
              },
              {
                "lerp": [
                  "intensity",
                  0.45,
                  1.0
                ]
              }
            ]
          }
        },
        "clampMax": "MAX_PIECES"
      },
      "spread": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "spread"
            },
            {
              "lerp": [
                "intensity",
                0.75,
                1.15
              ]
            }
          ]
        }
      },
      "launchSpeed": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "launchSpeed"
            },
            {
              "lerp": [
                "intensity",
                0.8,
                1.3
              ]
            }
          ]
        }
      },
      "gravity": {
        "type": "float",
        "from": {
          "baseline": "gravity"
        }
      },
      "flutter": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "flutter"
            },
            {
              "lerp": [
                "intensity",
                0.85,
                1.15
              ]
            }
          ]
        }
      },
      "pieceSize": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "pieceSize"
            },
            {
              "lerp": [
                "intensity",
                1.1,
                0.85
              ]
            }
          ]
        }
      },
      "spin": {
        "type": "float",
        "from": {
          "baseline": "spin"
        }
      },
      "overshoot": {
        "type": "float",
        "from": {
          "lerp": [
            "intensity",
            0.6,
            1.2
          ]
        }
      },
      "style": {
        "type": "float",
        "from": {
          "control": "whimsy"
        }
      }
    },
    "backends": {
      "webgl2": {
        "stage": "fullscreen-triangle",
        "blend": "screen",
        "shader": {
          "program": "confetti"
        }
      }
    },
    "fallbackOrder": [
      "webgl2"
    ]
  },
  "binding": {
    "note": "CROSS-PLATFORM uniform-binding contract (consumed by the @dopamine/build toolchain, not the runtime). Which render.params are NOT shader uniforms, the seed-keyed scatter field, the per-frame/host extras, and the texture samplers — one source of truth for the web u<Name> list, the Swift struct + packer, and the MSL struct. The toolchain STRIPS this (and `x-build`, `slug`, `kind`) from the .dope it embeds in each platform package, so the embedded runtime doc stays the portable, standalone-safe data spine.",
    "excludeParams": [
      "style",
      "overshoot",
      "durationMs"
    ],
    "scatterKey": "pieceSeed",
    "extras": [],
    "samplers": []
  },
  "x-build": {
    "note": "TOOLCHAIN build config (vendor-namespaced `x-` so runtime parsers ignore it; stripped from the embedded .dope). One block per platform: how `dopamine build` assembles the standalone, installable package into dist/<platform>/.",
    "swift": {
      "module": "DopamineEffectConfetti",
      "sources": "swift",
      "platforms": [
        "iOS(.v15)",
        "macOS(.v12)"
      ],
      "core": {
        "mode": "path",
        "package": "Dopamine",
        "product": "DopamineCore",
        "path": "swift"
      }
    },
    "web": {
      "package": "@dopamine/effect-confetti",
      "sources": "web"
    },
    "android": {
      "module": "dopamine-effect-confetti",
      "namespace": "ai.dopamine.effect.confetti",
      "sources": "android"
    }
  }
}
