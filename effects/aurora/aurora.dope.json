{
  "fmt": "dopamine-effect",
  "v": "1.0.0",
  "id": "dopamine.success.aurora",
  "slug": "aurora",
  "kind": "overlay",
  "meta": {
    "name": "Aurora",
    "description": "Hanging curtains of polar light that drape across the upper field, sway and sweep, then gently brighten and fade.",
    "tags": ["success", "ambient", "aurora", "directional", "curtain"]
  },
  "controls": {
    "mood": { "type": "enum", "label": "Mood", "default": "serene", "options": ["serene", "celebratory", "electric"], "ui": "segmented" },
    "intensity": { "type": "scalar", "label": "Intensity", "default": 0.7, "min": 0, "max": 1, "step": 0.01, "ui": "slider", "help": "Brightness, curtain coverage and band height." },
    "whimsy": { "type": "scalar", "label": "Whimsy", "default": 0.4, "min": 0, "max": 1, "step": 0.01, "ui": "slider", "help": "Photoreal soft volumetric curtains (0) to stylized hard cel / posterized ribbons (1)." },
    "seed": { "type": "int", "label": "Seed", "default": null, "nullable": true, "help": "Null = unique palette per fire; pin to reproduce." },
    "target": { "type": "selector", "label": "Target", "default": "document.body" }
  },
  "baselines": {
    "serene": {
      "durationMs": 3200, "lightness": 0.86, "chroma": 0.1, "hueCenter": 168, "hueRange": 70,
      "coverage": 0.55, "bandY": 0.66, "bandHeight": 0.28, "sway": 0.06, "striation": 0.6, "rays": 0.35, "overshoot": 0.4
    },
    "celebratory": {
      "durationMs": 2600, "lightness": 0.85, "chroma": 0.16, "hueCenter": 190, "hueRange": 200,
      "coverage": 0.7, "bandY": 0.64, "bandHeight": 0.31, "sway": 0.08, "striation": 0.72, "rays": 0.5, "overshoot": 0.7
    },
    "electric": {
      "durationMs": 2100, "lightness": 0.84, "chroma": 0.23, "hueCenter": 320, "hueRange": 150,
      "coverage": 0.85, "bandY": 0.62, "bandHeight": 0.34, "sway": 0.11, "striation": 0.88, "rays": 0.7, "overshoot": 1.0
    }
  },
  "palette": {
    "model": "oklch",
    "space": "linear-srgb",
    "generator": "golden-angle",
    "goldenAngleDeg": 137.50776405003785,
    "stops": 3,
    "hueSpread": 0.22,
    "lightness": { "baseline": "lightness", "perStop": [0.0, 0.06, -0.05] },
    "chroma": {
      "from": { "mul": [{ "baseline": "chroma" }, { "lerp": ["intensity", 0.7, 1.5] }] },
      "perStop": [0.0, 0.02, -0.01]
    },
    "seed": { "deterministic": true, "source": "controls.seed", "prng": "mulberry32" },
    "perMood": {
      "serene": { "hueCenter": 165, "hueRange": 110, "lightness": 0.84, "chroma": 0.11 },
      "celebratory": { "hueCenter": 200, "hueRange": 300, "lightness": 0.83, "chroma": 0.17 },
      "electric": { "hueCenter": 320, "hueRange": 180, "lightness": 0.82, "chroma": 0.24 }
    }
  },
  "tempo": {
    "durationMs": {
      "from": { "round": { "mul": [{ "baseline": "durationMs" }, { "lerp": ["intensity", 1.1, 0.9] }] } }
    },
    "frame": {
      "amp": { "envelope": [{ "input": "life" }, { "param": "overshoot" }] },
      "extras": {
        "sweep": { "mul": [0.02, { "div": [{ "input": "animMs" }, 1000] }, { "sub": [1, { "mul": [0.5, { "input": "life" }] }] }] }
      }
    },
    "reducedMotion": { "peakMs": 520, "holdMs": 520 }
  },
  "geometry": {
    "kind": "directional",
    "viewBox": [0, 0, 100, 100]
  },
  "render": {
    "params": {
      "exposure": { "type": "float", "from": { "lerp": ["intensity", 0.85, 1.55] } },
      "overshoot": {
        "type": "float",
        "from": { "mul": [{ "baseline": "overshoot" }, { "lerp": ["intensity", 0.7, 1.2] }] }
      },
      "coverage": {
        "type": "float", "clamp01": true,
        "from": { "mul": [{ "baseline": "coverage" }, { "lerp": ["intensity", 0.7, 1.25] }] }
      },
      "bandY": { "type": "float", "from": { "baseline": "bandY" } },
      "bandHeight": {
        "type": "float", "clamp01": true,
        "from": { "mul": [{ "baseline": "bandHeight" }, { "lerp": ["intensity", 0.85, 1.15] }] }
      },
      "sway": {
        "type": "float",
        "from": { "mul": [{ "baseline": "sway" }, { "lerp": ["intensity", 0.85, 1.2] }] }
      },
      "striation": {
        "type": "float", "clamp01": true,
        "from": { "mul": [{ "baseline": "striation" }, { "lerp": ["whimsy", 0.9, 1.1] }] }
      },
      "rays": {
        "type": "float", "clamp01": true,
        "from": { "mul": [{ "baseline": "rays" }, { "lerp": ["intensity", 0.8, 1.2] }] }
      },
      "style": { "type": "float", "from": { "control": "whimsy" } }
    },
    "shadowHeightFrac": { "mul": [{ "param": "bandHeight" }, 0.6] },
    "consts": { "MAX_CURTAINS": 7 },
    "config": { "usesOrigin": false },
    "backends": {
      "webgl2": {
        "stage": "fullscreen-triangle",
        "blend": "screen",
        "shader": { "program": "aurora" }
      }
    },
    "fallbackOrder": ["webgl2"]
  },

  "binding": {
    "note": "CROSS-PLATFORM uniform-binding contract. Which render.params are NOT shader uniforms, the seed-keyed scatter field, the per-frame/host extras, and the texture samplers — one source of truth for the web u<Name> list, the Swift struct + packer, and the MSL struct. SHIPS in the portable .dope (the runtime derives its uniform bindings from it); the toolchain consumes it too for the Metal struct codegen. Only `x-build`, `slug` and `kind` stay toolchain-only.",
    "excludeParams": ["style", "overshoot", "durationMs"],
    "scatterKey": "auroraSeed",
    "scatterWeb": "uSeed",
    "extras": [
      { "name": "sweep", "type": "float", "web": "uSweep", "note": "accumulated sideways sweep (fraction of width)" }
    ],
    "samplers": []
  },

  "x-build": {
    "note": "TOOLCHAIN build config (vendor-namespaced `x-` so runtime parsers ignore it; stripped from the embedded .dope). One block per platform: how `dopamine build` assembles the standalone, installable package into dist/<platform>/.",
    "shader": {
      "note": "Single-source shader: the canonical web GLSL is the ONLY hand-written shader; the MSL is TRANSPILED from it (no hand-ported .metal to drift). See tools/dopamine/src/shader.mjs.",
      "web": "web/src/aurora-shader.ts",
      "vertexExport": "AURORA_VERTEX_SRC",
      "fragmentExport": "AURORA_FRAGMENT_SRC",
      "generateMSL": true
    },
    "swift": {
      "module": "DopamineEffectAurora",
      "platforms": ["iOS(.v15)", "macOS(.v12)"],
      "core": { "mode": "path", "package": "Dopamine", "product": "DopamineCore", "path": "swift" }
    },
    "web": {
      "package": "@dopaminefx/effect-aurora",
      "sources": "web"
    },
    "android": {
      "module": "dopamine-effect-aurora",
      "namespace": "ai.dopamine.effect.aurora"
    }
  }
}
