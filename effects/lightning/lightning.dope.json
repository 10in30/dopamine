{
  "fmt": "dopamine-effect",
  "v": "1.0.0",
  "id": "dopamine.boost.lightning",
  "slug": "lightning",
  "kind": "overlay",
  "meta": {
    "name": "Lightning",
    "description": "A high-energy power-up / boost strike: a branching, fbm-perturbed electric arc cracks into the action point with a hard white flash, secondary forks, and a brief flicker afterglow. Electric OKLCH blues/violets to a hot white core.",
    "tags": [
      "boost",
      "power-up",
      "electric",
      "lightning",
      "anchored"
    ]
  },
  "controls": {
    "mood": {
      "type": "enum",
      "label": "Mood",
      "default": "electric",
      "options": [
        "serene",
        "celebratory",
        "electric"
      ],
      "ui": "segmented"
    },
    "intensity": {
      "type": "scalar",
      "label": "Intensity",
      "default": 0.85,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider",
      "help": "Bolt thickness, branch count, flash brightness."
    },
    "whimsy": {
      "type": "scalar",
      "label": "Whimsy",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider",
      "help": "Photoreal plasma glow (0) to flat cel comic-book bolt + harder strobe (1)."
    },
    "seed": {
      "type": "int",
      "label": "Seed",
      "default": null,
      "nullable": true,
      "help": "Null = unique bolt + palette per fire; pin to reproduce."
    },
    "origin": {
      "type": "point",
      "label": "Origin",
      "default": "center"
    },
    "target": {
      "type": "selector",
      "label": "Target",
      "default": "document.body"
    }
  },
  "baselines": {
    "serene": {
      "durationMs": 1400,
      "lightness": 0.82,
      "chroma": 0.12,
      "hueCenter": 245,
      "hueRange": 60,
      "thickness": 0.012,
      "jagged": 0.55,
      "branches": 0,
      "flashBright": 0.5,
      "flicker": 0.3,
      "overshoot": 0.7
    },
    "celebratory": {
      "durationMs": 1100,
      "lightness": 0.8,
      "chroma": 0.18,
      "hueCenter": 228,
      "hueRange": 110,
      "thickness": 0.016,
      "jagged": 0.85,
      "branches": 3,
      "flashBright": 0.8,
      "flicker": 0.65,
      "overshoot": 1.05
    },
    "electric": {
      "durationMs": 850,
      "lightness": 0.8,
      "chroma": 0.24,
      "hueCenter": 268,
      "hueRange": 90,
      "thickness": 0.02,
      "jagged": 1.15,
      "branches": 6,
      "flashBright": 1.1,
      "flicker": 1.0,
      "overshoot": 1.5
    }
  },
  "palette": {
    "model": "oklch",
    "space": "linear-srgb",
    "generator": "golden-angle",
    "goldenAngleDeg": 137.50776405003785,
    "stops": 3,
    "hueSpread": 0.4,
    "lightness": {
      "baseline": "lightness",
      "perStop": [
        0.08,
        0,
        -0.06
      ]
    },
    "chroma": {
      "from": {
        "mul": [
          {
            "baseline": "chroma"
          },
          {
            "lerp": [
              "intensity",
              0.7,
              1.4
            ]
          }
        ]
      },
      "perStop": [
        -0.02,
        0.02,
        0.01
      ]
    },
    "seed": {
      "deterministic": true,
      "source": "controls.seed",
      "prng": "mulberry32"
    },
    "perMood": {
      "serene": {
        "hueCenter": 245,
        "hueRange": 60,
        "lightness": 0.82,
        "chroma": 0.12
      },
      "celebratory": {
        "hueCenter": 228,
        "hueRange": 110,
        "lightness": 0.8,
        "chroma": 0.18
      },
      "electric": {
        "hueCenter": 268,
        "hueRange": 90,
        "lightness": 0.8,
        "chroma": 0.24
      }
    }
  },
  "tempo": {
    "durationMs": {
      "from": {
        "round": {
          "mul": [
            {
              "baseline": "durationMs"
            },
            {
              "lerp": [
                "intensity",
                1.15,
                0.9
              ]
            }
          ]
        }
      }
    },
    "frame": {
      "note": "The per-frame logic, datafied (was lightning-tempo): amp = the impact envelope; strike = strikeProgress(animMs), the ease-out-quint crack-in over the 130 ms STRIKE_MS window (the same clock the CPU bolt precompute keys off — see x-build.logic); flash = flashStrobe(life, flicker), an instantaneous near-white primary that decays fast (exp(-t/0.035)) plus 6 discrete afterglow re-pulses (sin^8 spikes) whose peaks decay across the tail, scaled by flicker.",
      "amp": {
        "envelope": [
          {
            "input": "life"
          },
          {
            "param": "overshoot"
          }
        ]
      },
      "extras": {
        "strike": {
          "sub": [
            1,
            {
              "pow": [
                {
                  "sub": [
                    1,
                    {
                      "clamp01": {
                        "div": [
                          {
                            "input": "animMs"
                          },
                          130
                        ]
                      }
                    }
                  ]
                },
                5
              ]
            }
          ]
        },
        "flash": {
          "add": [
            {
              "exp": {
                "div": [
                  {
                    "mul": [
                      -1,
                      {
                        "clamp01": {
                          "input": "life"
                        }
                      }
                    ]
                  },
                  0.035
                ]
              }
            },
            {
              "mul": [
                {
                  "pow": [
                    {
                      "max": [
                        0,
                        {
                          "sin": {
                            "mul": [
                              {
                                "clamp01": {
                                  "input": "life"
                                }
                              },
                              6,
                              3.141592653589793,
                              2
                            ]
                          }
                        }
                      ]
                    },
                    8
                  ]
                },
                {
                  "mul": [
                    {
                      "pow": [
                        {
                          "sub": [
                            1,
                            {
                              "clamp01": {
                                "input": "life"
                              }
                            }
                          ]
                        },
                        2.2
                      ]
                    },
                    0.28,
                    {
                      "param": "flicker"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },
    "reducedMotion": {
      "peakMs": 130,
      "holdMs": 300
    }
  },
  "render": {
    "params": {
      "exposure": {
        "type": "float",
        "from": {
          "lerp": [
            "intensity",
            0.9,
            1.6
          ]
        }
      },
      "thickness": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "thickness"
            },
            {
              "lerp": [
                "intensity",
                0.7,
                1.35
              ]
            }
          ]
        }
      },
      "jagged": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "jagged"
            },
            {
              "lerp": [
                "intensity",
                0.8,
                1.2
              ]
            }
          ]
        }
      },
      "branches": {
        "type": "int",
        "clampMax": "MAX_FORKS",
        "from": {
          "round": {
            "mul": [
              {
                "baseline": "branches"
              },
              {
                "lerp": [
                  "intensity",
                  0.5,
                  1.25
                ]
              }
            ]
          }
        }
      },
      "flashBright": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "flashBright"
            },
            {
              "lerp": [
                "intensity",
                0.6,
                1.4
              ]
            }
          ]
        }
      },
      "flicker": {
        "type": "float",
        "clamp01": true,
        "from": {
          "baseline": "flicker"
        }
      },
      "overshoot": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "overshoot"
            },
            {
              "lerp": [
                "intensity",
                0.7,
                1.25
              ]
            }
          ]
        }
      },
      "style": {
        "type": "float",
        "from": {
          "control": "whimsy"
        }
      }
    },
    "shadowHeightFrac": {
      "add": [
        {
          "mul": [
            {
              "param": "thickness"
            },
            14
          ]
        },
        0.4
      ]
    },
    "consts": {
      "MAX_FORKS": 7
    },
    "config": {
      "usesOrigin": true
    },
    "backends": {
      "webgl2": {
        "stage": "fullscreen-triangle",
        "blend": "screen",
        "shader": {
          "program": "lightning"
        }
      }
    },
    "fallbackOrder": [
      "webgl2"
    ]
  },
  "binding": {
    "note": "CROSS-PLATFORM uniform-binding contract. Which render.params are NOT shader uniforms, the seed-keyed scatter field, the per-frame/host extras, the texture samplers, and the per-frame ARRAYS — one source of truth for the web u<Name> list, the Swift struct + packer, and the MSL struct. SHIPS in the portable .dope (the runtime derives its uniform bindings from it); the toolchain consumes it too for the Metal struct codegen. Only `x-build`, `slug` and `kind` stay toolchain-only. lightning's CPU-precomputed bolt polyline rides the frameArrays seam declared in `arrays` (uVerts/uBoltMeta), not the uniform struct.",
    "excludeParams": [
      "style",
      "overshoot",
      "flicker",
      "durationMs",
      "jagged",
      "branches"
    ],
    "scatterKey": "boltSeed",
    "scatterWeb": "uSeed",
    "extras": [
      {
        "name": "strike",
        "type": "float",
        "web": "uStrike",
        "note": "tempo.frame.extras.strike — the 130 ms ease-out-quint crack-in"
      },
      {
        "name": "flash",
        "type": "float",
        "web": "uFlash",
        "note": "tempo.frame.extras.flash — the strobe (primary flash + flicker afterglow)"
      }
    ],
    "samplers": [],
    "arrays": [
      {
        "name": "verts",
        "web": "uVerts",
        "size": 2,
        "buffer": 1,
        "note": "CPU-precomputed bolt polyline (x-build.logic): vertex i of bolt b at [b*VERTS_PER_BOLT + i], device px, gl y-up. Web/GL bind by NAME as the uniform vec2 array; Metal binds it as `constant float2 *uVerts` at fragment buffer 1."
      },
      {
        "name": "meta",
        "web": "uBoltMeta",
        "size": 4,
        "buffer": 2,
        "note": "Per-bolt (segCount, radFrac, fadeMul, isMain); `constant float4 *uBoltMeta` at fragment buffer 2 on Metal."
      }
    ]
  },
  "x-build": {
    "note": "TOOLCHAIN build config (vendor-namespaced `x-` so runtime parsers ignore it; stripped from the embedded .dope). One block per platform: how `dopamine build` assembles the standalone, installable package into dist/<platform>/.",
    "shader": {
      "note": "Single-source shader: the canonical web GLSL is the ONLY hand-written shader; the MSL and the Android Kotlin are GENERATED from it. Its uVerts/uBoltMeta uniform ARRAYS ride the binding.arrays contract — kept as uniform arrays on web/GL, transpiled to constant floatN* fragment buffers on Metal.",
      "web": "web/src/lightning-shader.ts",
      "vertexExport": "LIGHTNING_VERTEX_SRC",
      "fragmentExport": "LIGHTNING_FRAGMENT_SRC",
      "generateMSL": true
    },
    "logic": {
      "note": "CPU-precomputed per-frame GEOMETRY logic, authored ONCE in the restricted TS subset (`src`) and TRANSPILED to LightningRenderer.swift / LightningRenderer.kt by tools/dopamine/src/logic.mjs. The generated factory shells wire its entry function into the runners' frameArrays seam via binding.arrays. `parityFixture` is the committed grid dumped from the web module (regen: node --experimental-strip-types effects/lightning/web/scripts/regen-logic-parity.mjs); it drives the generated pure-JVM JUnit test (synced into dopamine-core's testGenerated source set) and the generated XCTest target in the dist SwiftPM package.",
      "src": "web/src/lightning-logic.ts",
      "parityFixture": "web/test/lightning-logic-parity.json"
    },
    "swift": {
      "module": "DopamineEffectLightning",
      "platforms": [
        "iOS(.v15)",
        "macOS(.v12)"
      ],
      "core": {
        "mode": "path",
        "package": "Dopamine",
        "product": "DopamineCore",
        "path": "swift"
      }
    },
    "web": {
      "package": "@dopaminefx/effect-lightning",
      "sources": "web"
    },
    "android": {
      "module": "dopamine-effect-lightning",
      "namespace": "ai.dopamine.effect.lightning"
    }
  }
}
