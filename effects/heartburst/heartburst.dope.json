{
  "fmt": "dopamine-effect",
  "v": "1.0.0",
  "id": "dopamine.love.heartburst",
  "slug": "heartburst",
  "kind": "panel",
  "meta": {
    "name": "Heartburst",
    "description": "A love / like / favorite moment: a heart swells with a double-beat (lub-dub) then bursts into a flurry of small hearts that fly outward, arc, and fade — warm OKLCH reds/pinks/corals.",
    "tags": [
      "love",
      "like",
      "favorite",
      "heart",
      "burst"
    ]
  },
  "controls": {
    "mood": {
      "type": "enum",
      "label": "Mood",
      "default": "celebratory",
      "options": [
        "serene",
        "celebratory",
        "electric"
      ],
      "ui": "segmented"
    },
    "intensity": {
      "type": "scalar",
      "label": "Intensity",
      "default": 0.7,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider",
      "help": "Beat strength + number of burst hearts + glow."
    },
    "whimsy": {
      "type": "scalar",
      "label": "Whimsy",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "ui": "slider",
      "help": "Soft photoreal gloss heart (0) to flat cel sticker heart (1)."
    },
    "seed": {
      "type": "int",
      "label": "Seed",
      "default": null,
      "nullable": true,
      "help": "Null = unique warm palette + burst per fire; pin to reproduce."
    },
    "target": {
      "type": "selector",
      "label": "Target",
      "default": "document.body"
    }
  },
  "baselines": {
    "serene": {
      "durationMs": 2400,
      "lightness": 0.82,
      "chroma": 0.11,
      "hueCenter": 5,
      "hueRange": 40,
      "heartScale": 0.26,
      "burstCount": 10,
      "burstSpread": 0.32,
      "beatStrength": 0.6,
      "doubleBeat": 0.0
    },
    "celebratory": {
      "durationMs": 2000,
      "lightness": 0.78,
      "chroma": 0.17,
      "hueCenter": 12,
      "hueRange": 60,
      "heartScale": 0.3,
      "burstCount": 18,
      "burstSpread": 0.46,
      "beatStrength": 1.0,
      "doubleBeat": 1.0
    },
    "electric": {
      "durationMs": 1600,
      "lightness": 0.74,
      "chroma": 0.24,
      "hueCenter": 350,
      "hueRange": 50,
      "heartScale": 0.32,
      "burstCount": 26,
      "burstSpread": 0.58,
      "beatStrength": 1.35,
      "doubleBeat": 1.0
    }
  },
  "palette": {
    "model": "oklch",
    "space": "linear-srgb",
    "generator": "golden-angle",
    "goldenAngleDeg": 137.50776405003785,
    "stops": 3,
    "hueSpread": 0.18,
    "lightness": {
      "baseline": "lightness",
      "perStop": [
        0.0,
        0.07,
        -0.06
      ]
    },
    "chroma": {
      "from": {
        "mul": [
          {
            "baseline": "chroma"
          },
          {
            "lerp": [
              "intensity",
              0.75,
              1.4
            ]
          }
        ]
      },
      "perStop": [
        0.0,
        0.02,
        -0.01
      ]
    },
    "seed": {
      "deterministic": true,
      "source": "controls.seed",
      "prng": "mulberry32"
    },
    "perMood": {
      "serene": {
        "hueCenter": 5,
        "hueRange": 40,
        "lightness": 0.82,
        "chroma": 0.11
      },
      "celebratory": {
        "hueCenter": 12,
        "hueRange": 60,
        "lightness": 0.78,
        "chroma": 0.17
      },
      "electric": {
        "hueCenter": 350,
        "hueRange": 50,
        "lightness": 0.74,
        "chroma": 0.24
      }
    }
  },
  "tempo": {
    "durationMs": {
      "from": {
        "round": {
          "mul": [
            {
              "baseline": "durationMs"
            },
            {
              "lerp": [
                "intensity",
                1.1,
                0.9
              ]
            }
          ]
        }
      }
    }
  },
  "geometry": {
    "kind": "radial",
    "viewBox": [
      0,
      0,
      100,
      100
    ],
    "outlines": {
      "heart": {
        "role": "love-glyph",
        "note": "Parametric heart curve drawn in heartburst-renderer drawHeartburstPanel (hero + flurry)."
      }
    }
  },
  "render": {
    "params": {
      "exposure": {
        "type": "float",
        "from": {
          "lerp": [
            "intensity",
            0.85,
            1.45
          ]
        }
      },
      "heartScale": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "heartScale"
            },
            {
              "lerp": [
                "intensity",
                0.9,
                1.1
              ]
            }
          ]
        }
      },
      "burstCount": {
        "type": "int",
        "from": {
          "round": {
            "mul": [
              {
                "baseline": "burstCount"
              },
              {
                "lerp": [
                  "intensity",
                  0.5,
                  1.3
                ]
              }
            ]
          }
        }
      },
      "burstSpread": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "burstSpread"
            },
            {
              "lerp": [
                "intensity",
                0.85,
                1.2
              ]
            }
          ]
        }
      },
      "beatStrength": {
        "type": "float",
        "from": {
          "mul": [
            {
              "baseline": "beatStrength"
            },
            {
              "lerp": [
                "intensity",
                0.7,
                1.25
              ]
            }
          ]
        }
      },
      "doubleBeat": {
        "type": "float",
        "clamp01": true,
        "from": {
          "baseline": "doubleBeat"
        }
      },
      "glow": {
        "type": "float",
        "clamp01": true,
        "from": {
          "lerp": [
            "intensity",
            0.45,
            1.0
          ]
        }
      },
      "gloss": {
        "type": "float",
        "clamp01": true,
        "from": {
          "lerp": [
            "whimsy",
            1.0,
            0.0
          ]
        }
      },
      "halftone": {
        "type": "float",
        "clamp01": true,
        "from": {
          "lerp": [
            "whimsy",
            0.15,
            1.0
          ]
        }
      },
      "dotSize": {
        "type": "float",
        "from": {
          "lerp": [
            "whimsy",
            5.0,
            10.0
          ]
        }
      },
      "saturation": {
        "type": "float",
        "clamp01": true,
        "from": {
          "mul": [
            {
              "lerp": [
                "whimsy",
                0.35,
                1.0
              ]
            },
            {
              "lerp": [
                "intensity",
                0.8,
                1.1
              ]
            }
          ]
        }
      },
      "inkWeight": {
        "type": "float",
        "from": {
          "mul": [
            {
              "lerp": [
                "whimsy",
                3.0,
                9.0
              ]
            },
            {
              "lerp": [
                "intensity",
                0.9,
                1.1
              ]
            }
          ]
        }
      },
      "style": {
        "type": "float",
        "from": {
          "control": "whimsy"
        }
      }
    },
    "backends": {
      "webgl2": {
        "stage": "fullscreen-triangle",
        "blend": "screen",
        "shader": {
          "program": "heartburst"
        },
        "note": "Hybrid: a Canvas2D panel (hero heart + little hearts, vector heart curves) is uploaded as a texture; the shader adds bloom, gloss, halftone blush, beat flash and casts warm light + shadow."
      }
    },
    "fallbackOrder": [
      "webgl2"
    ]
  },
  "binding": {
    "note": "CROSS-PLATFORM uniform-binding contract (consumed by the @dopamine/build toolchain, not the runtime). Which render.params are NOT shader uniforms, the seed-keyed scatter field, the per-frame/host extras, and the texture samplers — one source of truth for the web u<Name> list, the Swift struct + packer, and the MSL struct. The toolchain STRIPS this (and `x-build`, `slug`, `kind`) from the .dope it embeds in each platform package, so the embedded runtime doc stays the portable, standalone-safe data spine.",
    "excludeParams": [
      "style",
      "heartScale",
      "burstCount",
      "burstSpread",
      "inkWeight",
      "beatStrength",
      "doubleBeat",
      "dotSize"
    ],
    "scatterKey": "heartburstSeed",
    "extras": [
      {
        "name": "presence",
        "type": "float",
        "web": "uPresence",
        "note": "panel opacity / presence 0..1"
      },
      {
        "name": "beat",
        "type": "float",
        "web": "uBeat",
        "note": "0..1 current beat amplitude (lub-dub thump)"
      },
      {
        "name": "burst",
        "type": "float",
        "web": "uBurst",
        "note": "0..1 burst progress (little hearts flying out)"
      },
      {
        "name": "flash",
        "type": "float",
        "web": "uFlash",
        "note": "0..1 warm beat/burst flash amount"
      },
      {
        "name": "dotSize",
        "type": "float",
        "web": "uDotSize",
        "note": "halftone cell size in device px (dpr-scaled)"
      }
    ],
    "samplers": [
      "uPanel"
    ]
  },
  "x-build": {
    "note": "TOOLCHAIN build config (vendor-namespaced `x-` so runtime parsers ignore it; stripped from the embedded .dope). One block per platform: how `dopamine build` assembles the standalone, installable package into dist/<platform>/.",
    "swift": {
      "module": "DopamineEffectHeartburst",
      "sources": "swift",
      "platforms": [
        "iOS(.v15)",
        "macOS(.v12)"
      ],
      "core": {
        "mode": "path",
        "package": "Dopamine",
        "product": "DopamineCore",
        "path": "swift"
      }
    },
    "web": {
      "package": "@dopamine/effect-heartburst",
      "sources": "web"
    },
    "android": {
      "module": "dopamine-effect-heartburst",
      "namespace": "ai.dopamine.effect.heartburst",
      "sources": "android"
    }
  }
}
