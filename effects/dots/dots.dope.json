{
  "fmt": "dopamine-effect",
  "v": "1.0.0",
  "id": "dopamine.loading.dots",
  "slug": "dots",
  "kind": "overlay",
  "meta": {
    "name": "Dots",
    "description": "A calm ambient 'thinking' indicator: a centred row of soft luminous dots that gently breathe while a brightness PULSE travels across them in sequence (the classic typing / loading read). Dopamine's second CONTINUOUS effect — like halo it LOOPS SEAMLESSLY via the first-class tempo.loop contract: all motion is driven by the standard periodic clocks uPhase/uLoopS the runners derive from tempo.loop.periodMs (1000 ms). The parser validates the seam invariants (the period is exactly 12 'animate-on-twos' steps, NPR_TIME_STEP_MS = 1000/12, and durationMs 4000 is exactly 4 periods), so the frame at t==durationMs matches t==0 at every whimsy. The conductor re-arms at durationMs until the host stops the play handle; amp is a steady gentle periodic breathe of phase (NOT envelope(life)), so there is no one-shot fade to break the seam. Fully declarative — no swift/ or android/ folder; the toolchain generates the Metal + Kotlin factories and shaders from this one .dope plus the single GLSL ES 3.00 source.",
    "tags": ["loading", "ambient", "continuous", "looping", "thinking"]
  },
  "controls": {
    "mood": {
      "type": "enum",
      "default": "celebratory",
      "options": ["serene", "celebratory", "electric"],
      "ui": "segmented"
    },
    "intensity": { "type": "scalar", "default": 0.7, "min": 0, "max": 1, "step": 0.01, "ui": "slider" },
    "whimsy": { "type": "scalar", "default": 0.5, "min": 0, "max": 1, "step": 0.01, "ui": "slider" },
    "seed": { "type": "int", "default": null, "nullable": true },
    "origin": { "type": "point", "default": "center" },
    "target": { "type": "selector", "default": "document.body" }
  },
  "baselines": {
    "serene": {
      "durationMs": 4000,
      "lightness": 0.86,
      "chroma": 0.08,
      "hueCenter": 225,
      "hueRange": 110,
      "dotCount": 3,
      "dotRadius": 0.032,
      "dotGap": 0.11,
      "breathe": 0.16,
      "chase": 0.6,
      "glow": 0.5
    },
    "celebratory": {
      "durationMs": 4000,
      "lightness": 0.82,
      "chroma": 0.15,
      "hueCenter": 200,
      "hueRange": 280,
      "dotCount": 4,
      "dotRadius": 0.03,
      "dotGap": 0.1,
      "breathe": 0.2,
      "chase": 0.85,
      "glow": 0.65
    },
    "electric": {
      "durationMs": 4000,
      "lightness": 0.8,
      "chroma": 0.22,
      "hueCenter": 195,
      "hueRange": 160,
      "dotCount": 5,
      "dotRadius": 0.026,
      "dotGap": 0.092,
      "breathe": 0.24,
      "chase": 1.1,
      "glow": 0.9
    }
  },
  "palette": {
    "model": "oklch",
    "space": "linear-srgb",
    "generator": "golden-angle",
    "goldenAngleDeg": 137.50776405003785,
    "stops": 3,
    "hueSpread": 0.55,
    "lightness": { "baseline": "lightness", "perStop": [0, 0.06, -0.05] },
    "chroma": {
      "from": { "mul": [{ "baseline": "chroma" }, { "lerp": ["intensity", 0.7, 1.5] }] },
      "perStop": [0, 0.02, -0.01]
    },
    "seed": { "deterministic": true, "source": "controls.seed", "prng": "mulberry32" },
    "perMood": {
      "serene": { "hueCenter": 225, "hueRange": 110, "lightness": 0.86, "chroma": 0.08 },
      "celebratory": { "hueCenter": 200, "hueRange": 280, "lightness": 0.82, "chroma": 0.15 },
      "electric": { "hueCenter": 195, "hueRange": 160, "lightness": 0.8, "chroma": 0.22 }
    }
  },
  "tempo": {
    "durationMs": { "from": { "baseline": "durationMs" } },
    "loop": { "periodMs": 1000 },
    "frame": {
      "amp": { "add": [0.85, { "mul": [0.15, { "sin": { "mul": [6.283185307179586, { "input": "phase" }] } }] }] },
      "extras": {}
    },
    "reducedMotion": { "peakMs": 0, "holdMs": 600 }
  },
  "render": {
    "params": {
      "exposure": { "type": "float", "from": { "lerp": ["intensity", 0.7, 1.45] } },
      "dotCount": {
        "type": "int",
        "from": { "round": { "baseline": "dotCount" } },
        "clampMax": "MAX_DOTS",
        "clampMin": "MIN_DOTS"
      },
      "dotRadius": {
        "type": "float",
        "from": { "mul": [{ "baseline": "dotRadius" }, { "lerp": ["intensity", 1.2, 0.82] }] }
      },
      "dotGap": { "type": "float", "from": { "baseline": "dotGap" } },
      "breathe": { "type": "float", "from": { "baseline": "breathe" } },
      "chase": {
        "type": "float",
        "from": { "mul": [{ "baseline": "chase" }, { "lerp": ["intensity", 0.8, 1.25] }] }
      },
      "glow": {
        "type": "float",
        "from": { "mul": [{ "baseline": "glow" }, { "lerp": ["intensity", 0.6, 1.3] }] }
      },
      "style": { "type": "float", "from": { "control": "whimsy" } }
    },
    "shadowHeightFrac": { "min": [{ "add": [{ "param": "dotRadius" }, 0.04] }, 1] },
    "consts": { "MAX_DOTS": 7, "MIN_DOTS": 2 },
    "config": { "usesOrigin": true },
    "backends": {
      "webgl2": {
        "stage": "fullscreen-triangle",
        "blend": "screen",
        "shader": { "program": "dots" }
      }
    },
    "fallbackOrder": ["webgl2"]
  },
  "binding": {
    "note": "CROSS-PLATFORM uniform-binding contract; SHIPS in the portable .dope. dotsSeed feeds the seeded palette only (no scatterWeb — the shader reads no seed uniform). dotCount is an integer uniform the shader reads to lay out the row. style is whimsy (set automatically), never a uniform.",
    "excludeParams": ["style"],
    "scatterKey": "dotsSeed",
    "extras": [],
    "samplers": []
  },
  "x-build": {
    "note": "TOOLCHAIN build config (stripped from the embedded .dope). Fully declarative: no swift/ or android/ folder — the factories + MSL + Kotlin shaders are generated from this .dope plus the one GLSL source.",
    "shader": { "note": "Single-source shader: web GLSL is the only hand-written shader; MSL+Android generated from it.", "web": "web/src/dots-shader.ts", "vertexExport": "DOTS_VERTEX_SRC", "fragmentExport": "DOTS_FRAGMENT_SRC", "generateMSL": true },
    "swift": {
      "module": "DopamineEffectDots",
      "platforms": ["iOS(.v15)", "macOS(.v12)"],
      "core": { "mode": "path", "package": "Dopamine", "product": "DopamineCore", "path": "swift" }
    },
    "web": {
      "package": "@dopaminefx/effect-dots",
      "sources": "web"
    },
    "android": {
      "module": "dopamine-effect-dots",
      "namespace": "ai.dopamine.effect.dots"
    }
  }
}
