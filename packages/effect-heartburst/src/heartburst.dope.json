{
  "fmt": "dopamine-effect",
  "v": "1.0.0",
  "id": "dopamine.love.heartburst",
  "meta": {
    "name": "Heartburst",
    "description": "A love / like / favorite moment: a heart swells with a double-beat (lub-dub) then bursts into a flurry of small hearts that fly outward, arc, and fade — warm OKLCH reds/pinks/corals.",
    "tags": ["love", "like", "favorite", "heart", "burst"]
  },
  "controls": {
    "mood": { "type": "enum", "label": "Mood", "default": "celebratory", "options": ["serene", "celebratory", "electric"], "ui": "segmented" },
    "intensity": { "type": "scalar", "label": "Intensity", "default": 0.7, "min": 0, "max": 1, "step": 0.01, "ui": "slider", "help": "Beat strength + number of burst hearts + glow." },
    "whimsy": { "type": "scalar", "label": "Whimsy", "default": 0.5, "min": 0, "max": 1, "step": 0.01, "ui": "slider", "help": "Soft photoreal gloss heart (0) to flat cel sticker heart (1)." },
    "seed": { "type": "int", "label": "Seed", "default": null, "nullable": true, "help": "Null = unique warm palette + burst per fire; pin to reproduce." },
    "target": { "type": "selector", "label": "Target", "default": "document.body" }
  },
  "baselines": {
    "serene": {
      "durationMs": 2400, "lightness": 0.82, "chroma": 0.11, "hueCenter": 5, "hueRange": 40,
      "heartScale": 0.26, "burstCount": 10, "burstSpread": 0.32, "beatStrength": 0.6, "doubleBeat": 0.0
    },
    "celebratory": {
      "durationMs": 2000, "lightness": 0.78, "chroma": 0.17, "hueCenter": 12, "hueRange": 60,
      "heartScale": 0.3, "burstCount": 18, "burstSpread": 0.46, "beatStrength": 1.0, "doubleBeat": 1.0
    },
    "electric": {
      "durationMs": 1600, "lightness": 0.74, "chroma": 0.24, "hueCenter": 350, "hueRange": 50,
      "heartScale": 0.32, "burstCount": 26, "burstSpread": 0.58, "beatStrength": 1.35, "doubleBeat": 1.0
    }
  },
  "palette": {
    "model": "oklch",
    "space": "linear-srgb",
    "generator": "golden-angle",
    "goldenAngleDeg": 137.50776405003785,
    "stops": 3,
    "hueSpread": 0.18,
    "lightness": { "baseline": "lightness", "perStop": [0.0, 0.07, -0.06] },
    "chroma": {
      "from": { "mul": [{ "baseline": "chroma" }, { "lerp": ["intensity", 0.75, 1.4] }] },
      "perStop": [0.0, 0.02, -0.01]
    },
    "seed": { "deterministic": true, "source": "controls.seed", "prng": "mulberry32" },
    "perMood": {
      "serene": { "hueCenter": 5, "hueRange": 40, "lightness": 0.82, "chroma": 0.11 },
      "celebratory": { "hueCenter": 12, "hueRange": 60, "lightness": 0.78, "chroma": 0.17 },
      "electric": { "hueCenter": 350, "hueRange": 50, "lightness": 0.74, "chroma": 0.24 }
    }
  },
  "tempo": {
    "durationMs": {
      "from": { "round": { "mul": [{ "baseline": "durationMs" }, { "lerp": ["intensity", 1.1, 0.9] }] } }
    }
  },
  "geometry": {
    "kind": "radial",
    "viewBox": [0, 0, 100, 100],
    "outlines": {
      "heart": { "role": "love-glyph", "note": "Parametric heart curve drawn in heartburst-renderer drawHeartburstPanel (hero + flurry)." }
    }
  },
  "render": {
    "params": {
      "exposure": { "type": "float", "from": { "lerp": ["intensity", 0.85, 1.45] } },
      "heartScale": {
        "type": "float",
        "from": { "mul": [{ "baseline": "heartScale" }, { "lerp": ["intensity", 0.9, 1.1] }] }
      },
      "burstCount": {
        "type": "int",
        "from": { "round": { "mul": [{ "baseline": "burstCount" }, { "lerp": ["intensity", 0.5, 1.3] }] } }
      },
      "burstSpread": {
        "type": "float",
        "from": { "mul": [{ "baseline": "burstSpread" }, { "lerp": ["intensity", 0.85, 1.2] }] }
      },
      "beatStrength": {
        "type": "float",
        "from": { "mul": [{ "baseline": "beatStrength" }, { "lerp": ["intensity", 0.7, 1.25] }] }
      },
      "doubleBeat": { "type": "float", "clamp01": true, "from": { "baseline": "doubleBeat" } },
      "glow": { "type": "float", "clamp01": true, "from": { "lerp": ["intensity", 0.45, 1.0] } },
      "gloss": { "type": "float", "clamp01": true, "from": { "lerp": ["whimsy", 1.0, 0.0] } },
      "halftone": { "type": "float", "clamp01": true, "from": { "lerp": ["whimsy", 0.15, 1.0] } },
      "dotSize": { "type": "float", "from": { "lerp": ["whimsy", 5.0, 10.0] } },
      "saturation": {
        "type": "float", "clamp01": true,
        "from": { "mul": [{ "lerp": ["whimsy", 0.35, 1.0] }, { "lerp": ["intensity", 0.8, 1.1] }] }
      },
      "inkWeight": {
        "type": "float",
        "from": { "mul": [{ "lerp": ["whimsy", 3.0, 9.0] }, { "lerp": ["intensity", 0.9, 1.1] }] }
      },
      "style": { "type": "float", "from": { "control": "whimsy" } }
    },
    "backends": {
      "webgl2": {
        "stage": "fullscreen-triangle",
        "blend": "screen",
        "shader": { "program": "heartburst" },
        "note": "Hybrid: a Canvas2D panel (hero heart + little hearts, vector heart curves) is uploaded as a texture; the shader adds bloom, gloss, halftone blush, beat flash and casts warm light + shadow."
      }
    },
    "fallbackOrder": ["webgl2"]
  }
}
