{
  "name": "@dopamine/effects",
  "version": "0.1.0",
  "description": "Batteries-included umbrella for Dopamine: registers all built-in effects + the celebrate* conveniences + the <dopamine-success> element.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": ["./src/index.ts", "./src/element.ts", "./dist/index.js", "./dist/element.js"],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@dopamine/core": "0.1.0",
    "@dopamine/effect-solarbloom": "0.1.0",
    "@dopamine/effect-inkstroke": "0.1.0",
    "@dopamine/effect-comic": "0.1.0",
    "@dopamine/effect-fail": "0.1.0",
    "@dopamine/effect-aurora": "0.1.0",
    "@dopamine/effect-ripple": "0.1.0",
    "@dopamine/effect-confetti": "0.1.0",
    "@dopamine/effect-heartburst": "0.1.0",
    "@dopamine/effect-lightning": "0.1.0"
  }
}
